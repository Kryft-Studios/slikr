{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "declaration": true,            
    "emitDeclarationOnly": false,   
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
}
